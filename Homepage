<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Homepage</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" integrity="sha384-0evYQh+pC20y5k4k3XBmuVjZ225mbB1VMW0/6jJEj9jHV3Da256kaZ1o3zGTj/1k" crossorigin="anonymous">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
    }

    header {
      background-color: #FFFFFF;
      color: #FFFFFF;
      padding: 0;
      text-align: center;
      position: relative; 
    }

    header img {
      width: 100%; 
      height: auto; 
    }

    .top-image {
      position: absolute;
      top: 13%; 
      left: 50%; 
      transform: translate(-50%, -50%); 
      height: auto; 
      width: 80%; 
    }

    h1 {
      font-size: 2em;
      margin: 0;
    }

    main {
      padding: 0px;
    }

    section {
      border: 1px solid #ddd;
      margin-bottom: 20px;
      padding: 20px;
    }

    h2 {
      font-size: 1.5em;
      margin: 0;
    }

    footer {
      background-color: #333;
      color: #fff;
      padding: 30px;
      text-align: center;
      margin-top: -25px;
    }
    .gray-background {
      background-color: #f4f4f4; 
      padding: 0px; 
      border: none; 
    }
    
    main img {
      max-width: 100%;
      height: auto; 
      display: block; 
      margin: 0 auto; 
    }

    .image-container {
      position: relative; 
      display: inline-block; 
      margin-top: -20px;
    }

    .image-container img:last-child {
      position: absolute; 
      top: 50%; 
      left: 50%; 
      transform: translate(-50%, -50%); 
      max-width: 60%; 
      height: auto; 
    }
  </style>
</head>
<body>
  <header>
    <img src="Header.png" class="top-image" alt="Логотип">
    <img src="Banner.png" alt="Фон">
  </header>
  <main>
    <img src="Products.png" alt="Зображення контенту">
    <section class="gray-background">
        <img src="VisionMission.png" alt="Описи">
		<img src="Mainactiv.png" alt="Актівітіс">
    </section>
    <section class="gray-background">
      <div class="image-container">
        <img src="Rectangle.png" alt="Низ">
        <img src="wr.png" alt="Профіль">
      </div>
    </section>
  </main>
  <footer>
    <img src="AGRIDERASEEDS.png" alt="Футер">
  </footer>
</body>
</html>
